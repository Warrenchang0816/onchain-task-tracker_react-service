# ============================================================
# react-service 環境變數範本
# 使用方式：cp .env.example .env，再填入真實值
#
# ⚠️  .env 已在 .gitignore 中排除，絕對不可提交至 Git
# ⚠️  所有 VITE_ 變數會被打包進前端產物，視同公開資訊
#     請勿在此處放任何私鑰或後端 Secret
# ============================================================


# ────────────────────────────────────────────────
# API 設定
#
# VITE_API_GO_SERVICE_URL：Go 後端的 API base URL
#   本機開發固定填 http://localhost:8081/api
# ────────────────────────────────────────────────
VITE_API_GO_SERVICE_URL=http://localhost:8081/api


# ────────────────────────────────────────────────
# 區塊鏈設定（前端）
#
# VITE_CHAIN_ID：目標鏈的 Chain ID，必須與後端 APP_CHAIN_ID 一致
#   MetaMask 也需切換至對應網路
#   Sepolia = 11155111 | Base Sepolia = 84532 | Base 主網 = 8453
#
# VITE_CHAIN_NAME：鏈的識別名稱（wagmi 顯示用）
#   sepolia | base-sepolia | base
#
# VITE_RPC_URL：前端讀鏈用的 Alchemy RPC endpoint（選填）
#   若留空，wagmi 使用公共 RPC（有速率限制，開發偶爾會卡）
#   建議填入與後端相同的 Alchemy URL
#   格式：https://eth-sepolia.g.alchemy.com/v2/<YOUR_API_KEY>
#
# VITE_REWARD_VAULT_ADDRESS：TaskRewardVault 合約地址
#   必須與後端 APP_REWARD_VAULT_ADDRESS 完全一致
#
# VITE_EXPLORER_URL：區塊瀏覽器 URL（用於顯示 tx hash 連結）
#   Sepolia：https://sepolia.etherscan.io
#   Base Sepolia：https://sepolia.basescan.org
#   Base 主網：https://basescan.org
# ────────────────────────────────────────────────
VITE_CHAIN_ID=11155111
VITE_CHAIN_NAME=sepolia
VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key_here
VITE_REWARD_VAULT_ADDRESS=0xYourContractAddressHere
VITE_EXPLORER_URL=https://sepolia.etherscan.io
